<button id="theme-toggle" aria-label="Toggle Dark Mode">
    <span class="light-icon">☀️</span>
    <span class="dark-icon">🌙</span>
</button>

<script>
    const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
    };

    // Register event listener on initial load
    document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);

    // Listen for view transitions if your template uses them
    document.addEventListener('astro:after-swap', () => {
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
        document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);
    });
</script>

<style>
    button {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.25rem;
        padding: 0.5rem;
    }

    /* Show / hide icons based on the html.dark class state */
    .dark-icon { display: none; }
    .light-icon { display: block; }

    :global(html.dark) .dark-icon { display: block; }
    :global(html.dark) .light-icon { display: none; }
</style>