---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
		<div class="toggle-wrapper">
			<ThemeToggle />
		</div>

	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--background); /* Swapped from white to support your dark mode */
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: background 0.3s ease;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		white-space: nowrap; /* Prevents your site title from breaking into two awkward lines */
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		position: relative;
		min-height: 56px;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Absolute centering for Desktop viewports */
	.internal-links {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 1rem;
	}

	.toggle-wrapper {
		margin-left: auto;
		display: flex;
		align-items: center;
		z-index: 10;
	}

	.social-links,
	.social-links a {
		display: flex;
	}

	/* ==========================================================================
	   NEW MOBILE RESPONSIVE MEDIA QUERY (For screens under 720px)
	   ========================================================================== */
	@media (max-width: 720px) {
		nav {
			flex-direction: column; /* Stacks the brand title above the links area */
			padding: 0.75rem 0;
			gap: 0.5rem;
		}

		h2 {
			font-size: 1.1em;
			text-align: center;
		}

		.internal-links {
			position: static;   /* Disables the absolute desktop overlap code */
			transform: none;    /* Clears the centering offset calculations */
			width: 100%;
			justify-content: center; /* Evenly groups links in a clean row below the title */
			gap: 0.75rem;
		}

		nav a {
			padding: 0.5em 0.4em; /* Slimmer padding profile so buttons don't clip off edges */
			font-size: 0.95rem;
		}

		.toggle-wrapper {
			position: absolute; /* Pins your moon/sun switch safely in the top corner out of the way */
			right: 0.5rem;
			top: 0.6rem;
			margin-left: 0;
		}

		.social-links {
			display: none;
		}
	}
</style>
